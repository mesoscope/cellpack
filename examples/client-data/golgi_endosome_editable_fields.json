{
  "editable_fields": [
    {
      "name": "Endosome Count",
      "description": "Number of spheres to be packed",
      "default": 86,
      "path": "composition.membrane.regions.interior.2.count",
      "data_type": "integer",
      "input_type": "slider",
      "min": 1,
      "max": 300
    },
    {
      "name": "Endosome Radius",
      "description": "Radius of spheres",
      "default": 2.6,
      "path": "objects.endosome.radius",
      "data_type": "float",
      "input_type": "slider",
      "min": 0.01,
      "max": 9.259,
      "unit": "µm",
      "conversion_factor": 0.108
    },
    {
      "name": "Spatial Distribution Rule",
      "description": "Choose one of the available options listed in the \"gradients\" dictionary. Select \"No Gradient\" to pack without gradient.",
      "path": "objects.endosome.gradient",
      "data_type": "gradient",
      "input_type": "gradient",
      "gradient_options": [
        {
          "display_name": "Nuclear Bias",
          "value": "nucleus_gradient",
          "path": "objects.endosome.gradient",
          "packing_mode": "gradient",
          "packing_mode_path": "objects.endosome.packing_mode",
          "strength_path": "gradients.nucleus_gradient.weight_mode_settings.decay_length",
          "strength_default": 0.1,
          "strength_display_name": "Nucleus Decay Length",
          "strength_description": "Smaller decay length indicates stronger bias",
          "strength_min": 0.01
        },
        {
          "display_name": "Membrane Bias",
          "value": "membrane_gradient",
          "path": "objects.endosome.gradient",
          "packing_mode": "gradient",
          "packing_mode_path": "objects.endosome.packing_mode",
          "strength_path": "gradients.membrane_gradient.weight_mode_settings.decay_length",
          "strength_default": 0.01,
          "strength_display_name": "Membrane Decay Length",
          "strength_description": "Smaller decay length indicates stronger bias",
          "strength_min": 0.01
        },
        {
          "display_name": "Apical Bias",
          "value": "apical_gradient",
          "path": "objects.endosome.gradient",
          "packing_mode": "gradient",
          "packing_mode_path": "objects.endosome.packing_mode",
          "strength_path": "gradients.apical_gradient.weight_mode_settings.decay_length",
          "strength_default": 0.01,
          "strength_display_name": "Apical Decay Length",
          "strength_description": "Smaller decay length indicates stronger bias",
          "strength_min": 0.01
        },
        {
          "display_name": "Golgi Bias",
          "value": "struct_gradient",
          "path": "objects.endosome.gradient",
          "packing_mode": "gradient",
          "packing_mode_path": "objects.endosome.packing_mode",
          "strength_path": "gradients.struct_gradient.weight_mode_settings.decay_length",
          "strength_default": 0.1,
          "strength_display_name": "Golgi Decay Length",
          "strength_description": "Smaller decay length indicates stronger bias",
          "strength_min": 0.01
        },
        {
          "display_name": "Unbiased",
          "value": "random",
          "path": "objects.endosome.packing_mode",
          "packing_mode": "random",
          "packing_mode_path": "objects.endosome.packing_mode"
        }
      ]
    }
  ]
}
